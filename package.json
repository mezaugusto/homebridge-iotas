{
  "name": "homebridge-iotas-v2",
  "displayName": "Homebridge IOTAS",
  "version": "3.0.2",
  "description": "A homebridge plugin to control IOTAS smart home devices. IOTAS was acquired by ADT in June 2022, IOTAS may transition to the ADT Multifamily app at some point.",
  "type": "module",
  "main": "dist/src/index.js",
  "files": [
    "dist/src/",
    "config.schema.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "homebridge-plugin",
    "iotas",
    "adt",
    "smart-home",
    "multifamily"
  ],
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "tsc --watch",
    "test": "tsc && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "author": "Augusto Meza <mezaugusto@proton.me>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mezaugusto/homebridge-iotas.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "homebridge": "^1.8.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "bugs": {
    "url": "https://github.com/mezaugusto/homebridge-iotas/issues"
  },
  "homepage": "https://github.com/mezaugusto/homebridge-iotas#readme",
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 120
  }
}
